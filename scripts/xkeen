#!/bin/sh
#
# XKeen — главный CLI-точка входа.
# Большая часть логики вынесена в _xkeen/06_dispatch/*.sh как cmd_<command>() функции.
# Здесь — только: setup (rename _xkeen → .xkeen), импорт модулей, парсинг $@,
# сопоставление флагов с командами.
#
# Файлы команд группируются по теме, каждая ≤200 строк. Список см. в
# _xkeen/06_dispatch/00_dispatch_import.sh.

# Определение директории, где находится xkeen
script_dir="$(cd "$(dirname "$0")" && pwd)"

# Скрываем основную директорию xkeen
install_xkeen_rename() {
    source_dir="_xkeen"
    target_dir=".xkeen"
    source_path="$script_dir/$source_dir"
    target_path="$script_dir/$target_dir"

    if [ -d "$source_path" ]; then
        if [ -d "$target_path" ]; then
            rm -rf "$target_path" 2>/dev/null
        fi
        mv "$source_path" "$target_path"
    fi
    rm /opt/root/install.sh 2>/dev/null
}
install_xkeen_rename

add_chmod_init() {
    [ -f "$initd_file" ] && chmod +x "$initd_file"
}

for arg in "$@"; do
    [ "$arg" = "-toff" ] && touch "/tmp/toff"
done

# Импортируем модули (вкл. CLI-диспетчер с cmd_<command>() функциями)
. "$script_dir/.xkeen/import.sh"

xkeen_info() {
    # Проверяем версию XKeen
    info_version_xkeen

    # Проверяем актуальность XKeen
    info_compare_xkeen
}

xkeen_set_info() {
    # Определяем архитектуру процессора
    info_cpu

    # Проверяем установку Xray
    info_xray

    # Проверяем установку Mihomo
    info_mihomo

    # Проверяем установленные базы GeoSite
    info_geosite

    # Проверяем установленные базы GeoiIP
    info_geoip

    # Проверяем статус автообновления
    info_cron

    # Проверяем версию Xray
    info_version_xray

    # Проверяем версию Mihomo и Yq
    info_version_mihomo
    info_version_yq
}

while [ $# -gt 0 ]; do
    case "$1" in
        # === Установка / переустановка / удаление ===
        -i|-install)        cmd_install ;;
        -io)                cmd_install_offline ;;
        -k)                 cmd_reinstall ;;
        -k_post_install)    cmd_reinstall_post ;;
        -remove)            cmd_remove_full ;;
        -dx)                cmd_remove_xray ;;
        -dm)                cmd_remove_mihomo ;;
        -dk)                cmd_remove_xkeen ;;
        -dgi)               cmd_remove_geoip ;;
        -dgs)               cmd_remove_geosite ;;

        # === Обновление ===
        -uk)                cmd_update_xkeen ;;
        -uk_post_update)    cmd_update_xkeen_post ;;
        -ux)                cmd_update_xray ;;
        -um)                cmd_update_mihomo ;;
        -ug)                cmd_update_geo ;;

        # === GeoFile / GeoIPSET ===
        -g)                 cmd_install_geo ;;
        -gips)              cmd_install_geoipset ;;
        -dgips)             cmd_remove_geoipset ;;

        # === Cron / init ===
        -ugc)               cmd_setup_cron_geo ;;
        -dgc)               cmd_remove_cron_geo ;;
        -ri)                cmd_recreate_init ;;

        # === Резервные копии ===
        -kb)                cmd_backup_xkeen ;;
        -kbr)               cmd_restore_xkeen ;;
        -xb)                cmd_backup_xray ;;
        -xbr)               cmd_restore_xray ;;
        -mb)                cmd_backup_mihomo ;;
        -mbr)               cmd_restore_mihomo ;;

        # === Жизненный цикл и настройки запуска ===
        -start)             cmd_start ;;
        -stop)              cmd_stop ;;
        -restart)           cmd_restart ;;
        -status)            cmd_status ;;
        -auto)              cmd_autostart ;;
        -fd)                cmd_toggle_fd ;;

        # === Порты ===
        -ap)                shift; cmd_ports_add "$@" ;;
        -dp)                shift; cmd_ports_del "$@" ;;
        -cp)                cmd_ports_list ;;
        -ape)               shift; cmd_ports_exclude_add "$@" ;;
        -dpe)               shift; cmd_ports_exclude_del "$@" ;;
        -cpe)               cmd_ports_exclude_list ;;
        -tp)                cmd_ports_listening ;;

        # === Тоглы и выбор ядра ===
        -channel)           cmd_change_channel ;;
        -xray)              cmd_use_xray ;;
        -mihomo)            cmd_use_mihomo ;;
        -ipv6)              cmd_toggle_ipv6 ;;
        -dns)               cmd_toggle_dns ;;
        -pr)                cmd_toggle_router_proxy ;;
        -extmsg)            cmd_toggle_extmsg ;;
        -cbk)               cmd_toggle_backup ;;
        -aghfix)            cmd_toggle_aghfix ;;

        # === Прочее / информация ===
        -d)                 shift; cmd_set_delay "$1" ;;
        -diag)              cmd_diagnostic ;;
        -modules)           cmd_modules_obsolete ;;
        -delmodules)        cmd_modules_remove_obsolete ;;
        -about)             cmd_about ;;
        -ad|-donate)        cmd_donate ;;
        -af|-feedback)      cmd_feedback ;;
        -h|-help)           cmd_help ;;
        -v|-version)        cmd_version ;;
        -toff)              cmd_toff_noop ;;

        *)                  cmd_unknown "$1" ;;
    esac
    shift
done
